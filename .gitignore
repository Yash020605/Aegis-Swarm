# ──────────────────────────────────────────────────────────────────────
# AEGIS Swarm — Root .gitignore
# ──────────────────────────────────────────────────────────────────────

# ── Secrets — NEVER commit these ─────────────────────────────────────
.env
*.pem
*.key

# ── Python ────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/
*.egg
.venv/
venv/
env/
*.pyc

# ── YOLOv8 model weights (large binary files) ─────────────────────────
*.pt
*.onnx
*.torchscript

# ── Next.js / Node ────────────────────────────────────────────────────
aegis-dashboard/.next/
aegis-dashboard/node_modules/
aegis-dashboard/.env.local
aegis-dashboard/.env.production

# ── OS / Editor ───────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/settings.json
*.swp
*.swo

# ── Logs ──────────────────────────────────────────────────────────────
*.log
npm-debug.log*
