# ──────────────────────────────────────────────────────────────────────
# AEGIS Swarm Engine — Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.
# ──────────────────────────────────────────────────────────────────────

# ── Task 1: Groq API key ──────────────────────────────────────────────
# Get yours (free) at: https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key-here

# ── Task 3: JWT Secret ────────────────────────────────────────────────
# Use a long random string in production.
# Generate with: py -c "import secrets; print(secrets.token_hex(32))"
AEGIS_SECRET_KEY=replace-with-a-long-random-secret-key

# ── (Optional) Override mock admin credentials ────────────────────────
# AEGIS_ADMIN_USERNAME=admin
# AEGIS_ADMIN_PASSWORD=aegis2024
